{
  "name": "Minimal Information",
  "description": "Tests the AI's behavior with severely limited data: no fees, no scores, no demand signals, no seller details, minimal content, and flat response format to evaluate graceful degradation",
  "config": {
    "pricing": {
      "format": "number_only",
      "feeVisibility": "hidden"
    },
    "scores": {
      "includeDealScore": false,
      "includeValueScore": false,
      "includeDealFlags": false,
      "includeSavings": false,
      "includeRelativeValue": false
    },
    "demand": {
      "includeViewCounts": false,
      "includeSoldData": false,
      "includePriceTrend": false,
      "includeDemandLevel": false,
      "includePriceHistory": false
    },
    "seller": {
      "includeSellerDetails": false,
      "includeRefundPolicy": false,
      "includeTransferMethod": false
    },
    "content": {
      "eventDescriptions": "minimal",
      "venueInfo": "name_only",
      "includeBundleOptions": false,
      "includePremiumFeatures": false,
      "buttonText": "Purchase"
    },
    "api": {
      "responseFormat": "flat",
      "dateFormat": "YYYY-MM-DD",
      "includeSeatQuality": false
    }
  }
}
